# Copy to `.env` in the project root. Never commit `.env`.
#
# JIRA_* is read only by server/jira-proxy.mjs. The React app never sees your API token.

# Atlassian API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_HOST=https://redhat.atlassian.net
JIRA_EMAIL=you@redhat.com
JIRA_API_TOKEN=your_atlassian_api_token_here

# Optional
# JIRA_PROXY_PORT=3848
# JIRA_JQL=project = CPUX AND component = "HCC" AND issuetype in (Epic, Story) AND text ~ "research"
# JIRA_PROXY_DEBUG=1
